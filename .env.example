# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change-me-in-prod
DEBUG=false

# S2.12 Auth + Demo
DEMO_MODE=true
QUICK_DEMO_PUBLIC=true
REQUIRE_LOGIN_FOR_TEACHER=true
REQUIRE_LOGIN_FOR_STUDENT=true

# Web Server Configuration
WEB_PORT=5001

# Database Configuration
# Leave empty to use JSON file storage (default)
# For PostgreSQL: postgresql://user:password@host:port/database
# For SQLite: sqlite:///path/to/database.db
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/teacher_in_loop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=teacher_in_loop
POSTGRES_PORT=5432

# Storage Backend Selection
# Set to 'true' to use database storage, 'false' to use JSON files (default)
USE_DB_STORAGE=false

# Data Directory (relative to app root or absolute path)
DATA_DIR=data

# LLM Provider Configuration (default: OpenAI only, gpt-4o-mini)
# Options: openai | mock (qwen disabled by default)
LLM_PROVIDER=openai
LLM_PROVIDER_PRIMARY=openai
LLM_PROVIDER_FALLBACK=openai
LLM_PROVIDER_STRATEGY=primary_with_fallback
LLM_PRIMARY=openai
LLM_FALLBACK=openai
LLM_ALLOW_UNIMPLEMENTED_PRIMARY=false

# Qwen (disabled by default; set QWEN_ENABLED=true and QWEN_API_KEY to use)
QWEN_ENABLED=false
QWEN_IMPLEMENTED=true
# QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus

# OpenAI Configuration (default provider)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_ENABLED=true
OPENAI_IMPLEMENTED=true
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Mock Provider Configuration (for testing, no API key needed)
MOCK_MODEL=mock-model-v1

# Feature Flags (optional, defaults in code)
# FEATURE_ALIGNMENT_CHECK=true
# FEATURE_QUALITY_ANALYSIS=true
# FEATURE_AI_SUGGESTIONS=true

# Spec Validation Configuration
# Set to 'true' to allow public access to /api/cscl/spec/validate (development only)
# Set to 'false' to require teacher/admin authentication (default, recommended for production)
SPEC_VALIDATE_PUBLIC=false
