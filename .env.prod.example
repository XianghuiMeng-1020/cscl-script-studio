# S2.7 Production Environment Template
# Copy to .env and fill values before deploy
# Required: SECRET_KEY, DATABASE_URL (for production DB)

APP_ENV=production
FLASK_ENV=production
DEBUG=false
WEB_PORT=5001
LOG_LEVEL=INFO

# CRITICAL: Use strong random secret in production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-with-secrets-token-hex-32>

# Production Database (required for go-live)
DATABASE_URL=postgresql://user:password@host:5432/dbname
USE_DB_STORAGE=true

# CORS: Comma-separated allowed origins (production domains)
# Example: https://csc.example.com,https://app.example.com
# CORS: comma-separated production domains (e.g. https://csc.example.com)
CORS_ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001

# LLM Provider: openai | qwen | mock (default openai for quality)
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-openai-key>
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-3.5-turbo

QWEN_API_KEY=<optional-qwen-key>
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Spec validation: false = require auth (production default)
SPEC_VALIDATE_PUBLIC=false
